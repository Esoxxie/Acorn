rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function hasAllowlistEntry(uid) {
      return exists(/databases/$(database)/documents/allowedUsers/$(uid));
    }

    function isAllowedUser(uid) {
      return hasAllowlistEntry(uid) || exists(/databases/$(database)/documents/users/$(uid));
    }

    match /allowedUsers/{uid} {
      allow read, write: if false;
    }

    match /users/{uid} {
      allow read, update: if isOwner(uid) && isAllowedUser(uid);
      allow create: if isOwner(uid) && hasAllowlistEntry(uid);
      allow delete: if false;

      match /meals/{mealId} {
        allow read, create, update, delete: if isOwner(uid) && isAllowedUser(uid);
      }

      match /savedFoods/{foodId} {
        allow read, create, update, delete: if isOwner(uid) && isAllowedUser(uid);
      }

      match /usage/{dayId} {
        allow read, write: if isOwner(uid) && isAllowedUser(uid);
      }
    }
  }
}
